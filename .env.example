# T Pay environment example
# Copy to .env and fill in testnet values only.
# Never commit real keys, private keys, seed phrases, or backend secrets.

# Circle / Arc App Kit
EXPO_PUBLIC_APP_KIT_PROJECT_ID=
EXPO_PUBLIC_CIRCLE_APP_KIT_KEY=

# Arc Testnet
EXPO_PUBLIC_ARC_RPC_URL=
EXPO_PUBLIC_ARC_CHAIN_ID=5042002
EXPO_PUBLIC_ARC_USDC_ADDRESS=
EXPO_PUBLIC_ARC_DEX_ROUTER_ADDRESS=
EXPO_PUBLIC_ARC_EXPLORER=

# Optional feature flags / readiness
EXPO_PUBLIC_UNIFIED_BALANCE_ENABLED=
EXPO_PUBLIC_SWAP_ENABLED=

# Optional Supabase split-bill sync
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional app infrastructure
EXPO_PUBLIC_TPAY_BACKEND_URL=
EXPO_PUBLIC_MERCHANT_SETTLEMENT_ADDRESS=
EXPO_PUBLIC_RECURRING_ADDRESS=
EXPO_PUBLIC_INVOICE_ADDRESS=
EXPO_PUBLIC_MARKETS_ADDRESS=
EXPO_PUBLIC_PIN_SECURITY_ENABLED=true

# Backend-only secrets such as CIRCLE_API_KEY belong in backend-samples/next-app/.env, not the Expo app .env.
